<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane prefHeight="768.0" prefWidth="1280.0"
            styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.digitalprimaryschool.digitalprimaryschool.HelloController">

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <!-- ══════════════════════════════════════
         SIDEBAR (inchangée)
    ══════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260.0" spacing="25.0">
            <padding>
                <Insets top="30.0" right="20.0" bottom="30.0" left="20.0"/>
            </padding>

            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <Label text="PRINCIPAL" styleClass="menu-section-title"/>
                <Button fx:id="btnDashboard" onAction="#handleDashboardHome" styleClass="sidebar-btn, active">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Tableau de bord" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Élèves" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Enseignants" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button fx:id="btnClasses" onAction="#handleClassesMenu" styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Classes" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button fx:id="btnRegisterStudent" onAction="#handleAddStudentMenu" styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Enregistrer un élève" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Emploi du temps" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Notes &amp; Bulletins" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Label text="SYSTÈME" styleClass="menu-section-title">
                    <VBox.margin><Insets top="20.0"/></VBox.margin>
                </Label>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Notifications" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
                <Button styleClass="sidebar-btn">
                    <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Label text="" styleClass="icon-font"/>
                        <Label text="Paramètres" styleClass="btn-text"/>
                    </HBox></graphic>
                </Button>
            </VBox>

            <Button styleClass="sidebar-btn, logout-btn">
                <graphic><HBox spacing="15.0" alignment="CENTER_LEFT">
                    <Label text="" styleClass="icon-font"/>
                    <Label text="Déconnexion" styleClass="btn-text"/>
                </HBox></graphic>
            </Button>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════
         ZONE CENTRALE : AppBar + Contenu
    ══════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- ── APPBAR CUSTOM ── -->
            <HBox fx:id="appBar" styleClass="app-bar" alignment="CENTER_LEFT">

                <!-- Bouton toggle sidebar (optionnel) -->
                <Button styleClass="appbar-icon-btn">
                    <graphic><Label text="&#xE700;" styleClass="icon-font appbar-icon"/></graphic>
                </Button>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>



            </HBox>

            <!-- ── CONTENU PAGES ── -->
            <VBox fx:id="contentArea" VBox.vgrow="ALWAYS"
                  styleClass="workspace-container"
                  fillWidth="true"/>

        </VBox>
    </center>

</BorderPane>