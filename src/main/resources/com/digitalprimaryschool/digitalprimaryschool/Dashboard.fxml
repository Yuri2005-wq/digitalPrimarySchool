<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" styleClass="page-scroll"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.digitalprimaryschool.digitalprimaryschool.HelloController">

    <VBox spacing="22" styleClass="page-content">
        <padding>
            <Insets top="26" right="32" bottom="32" left="32"/>
        </padding>

        <!-- En-tête -->
        <VBox spacing="4">
            <Label text="Tableau de bord" styleClass="page-title"/>
            <Label text="Bienvenue, voici un aperçu de votre établissement" styleClass="page-subtitle"/>
        </VBox>

        <!-- Cartes statistiques -->
        <HBox spacing="18">
            <VBox styleClass="card,stat-card" HBox.hgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Total élèves" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon,icon-gray">
                        <FontIcon iconLiteral="fth-users" iconSize="18"/>
                    </StackPane>
                </HBox>
                <Label text="1,245" styleClass="stat-value"/>
                <Label text="↑ 12 cette semaine" styleClass="stat-trend,trend-up"/>
            </VBox>

            <VBox styleClass="card,stat-card" HBox.hgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Enseignants" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon,icon-orange">
                        <FontIcon iconLiteral="fth-award" iconSize="18"/>
                    </StackPane>
                </HBox>
                <Label text="68" styleClass="stat-value"/>
                <Label text="+2 ce mois" styleClass="stat-trend,trend-neutral"/>
            </VBox>

            <VBox styleClass="card,stat-card" HBox.hgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Classes actives" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon,icon-blue">
                        <FontIcon iconLiteral="fth-book-open" iconSize="18"/>
                    </StackPane>
                </HBox>
                <Label text="42" styleClass="stat-value"/>
                <Label text="Stable" styleClass="stat-trend,trend-neutral"/>
            </VBox>

            <VBox styleClass="card,stat-card" HBox.hgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="Taux de présence" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon,icon-green">
                        <FontIcon iconLiteral="fth-trending-up" iconSize="18"/>
                    </StackPane>
                </HBox>
                <Label text="93.2%" styleClass="stat-value"/>
                <Label text="↑ 1.5% vs sem. dernière" styleClass="stat-trend,trend-up"/>
            </VBox>
        </HBox>

        <!-- Graphiques -->
        <HBox spacing="18">
            <VBox styleClass="card,chart-card" HBox.hgrow="ALWAYS" spacing="14">
                <Label text="Présence hebdomadaire" styleClass="card-title"/>
                <BarChart fx:id="presenceChart" styleClass="dashboard-chart"
                          legendVisible="false" animated="false"
                          VBox.vgrow="ALWAYS" minHeight="240">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <VBox styleClass="card,chart-card" HBox.hgrow="ALWAYS" spacing="14">
                <Label text="Moyenne générale" styleClass="card-title"/>
                <LineChart fx:id="averageChart" styleClass="dashboard-chart"
                           legendVisible="false" animated="false"
                           VBox.vgrow="ALWAYS" minHeight="240">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </HBox>

        <!-- Listes -->
        <HBox spacing="18">
            <VBox styleClass="card,list-card" HBox.hgrow="ALWAYS" spacing="16">
                <Label text="Activité récente" styleClass="card-title"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon,icon-blue,icon-sm">
                        <FontIcon iconLiteral="fth-user-plus" iconSize="15"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Nouvel élève inscrit : Amina Benali" styleClass="activity-title"/>
                        <Label text="Il y a 5 min" styleClass="activity-time"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon,icon-green,icon-sm">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="15"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Bulletin du 2e trimestre validé - 5ème B" styleClass="activity-title"/>
                        <Label text="Il y a 1 h" styleClass="activity-time"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="stat-icon,icon-orange,icon-sm">
                        <FontIcon iconLiteral="fth-dollar-sign" iconSize="15"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Paiement reçu - Tranche 2, Élève #1187" styleClass="activity-title"/>
                        <Label text="Il y a 3 h" styleClass="activity-time"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="card,list-card" HBox.hgrow="ALWAYS" spacing="16">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fth-calendar" iconSize="16" styleClass="card-title-icon"/>
                    <Label text="Événements à venir" styleClass="card-title"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT" styleClass="event-row">
                    <Label text="28 Mar" styleClass="event-date"/>
                    <Label text="Conseil de classe - 3ème" styleClass="event-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Réunion" styleClass="event-tag,tag-blue"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT" styleClass="event-row">
                    <Label text="02 Avr" styleClass="event-date"/>
                    <Label text="Date limite - paiement tranche 3" styleClass="event-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Paiement" styleClass="event-tag,tag-orange"/>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT" styleClass="event-row">
                    <Label text="10 Avr" styleClass="event-date"/>
                    <Label text="Distribution des bulletins" styleClass="event-title" HBox.hgrow="ALWAYS"/>
                    <Label text="Académique" styleClass="event-tag,tag-green"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
