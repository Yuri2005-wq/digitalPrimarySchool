<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    MainWindow.fxml – Fenêtre principale (shell)
    Contrôleur : MainWindowController.java
    Cette vue charge dynamiquement les sous-vues dans le stackPaneWorkspace.
-->
<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cm.siantou.ecole.controller.MainWindowController"
    stylesheets="@../css/style.css"
    prefWidth="1280"
    prefHeight="768">

    <!-- ============================================================
         HEADER (TOP)
         ============================================================ -->
    <top>
        <HBox
            styleClass="header-bar"
            alignment="CENTER_LEFT"
            spacing="0">

            <!-- Logo + Nom école -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🏫" style="-fx-font-size: 26px;" />
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label
                        fx:id="lblNomEcole"
                        text="École Primaire Bilingue"
                        styleClass="header-logo-text" />
                    <Label
                        fx:id="lblVilleEcole"
                        text="Yaoundé, Cameroun"
                        styleClass="header-school-name" />
                </VBox>
            </HBox>

            <!-- Espace flexible -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Année scolaire active -->
            <HBox alignment="CENTER" spacing="16">
                <Label
                    fx:id="lblAnneeScolaire"
                    text="📅  2025 / 2026"
                    styleClass="header-annee" />

                <!-- Sélecteur de langue -->
                <ComboBox
                    fx:id="cmbLangue"
                    styleClass="lang-selector"
                    prefWidth="110" />

                <!-- Séparateur vertical -->
                <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.2);" prefHeight="36" />

                <!-- Infos utilisateur -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label
                            fx:id="lblNomUtilisateur"
                            text="Jean MBARGA"
                            styleClass="header-user-name" />
                        <Label
                            fx:id="lblRoleUtilisateur"
                            text="Économe / Secrétaire"
                            styleClass="header-user-role" />
                    </VBox>
                    <!-- Avatar initiales -->
                    <Button
                        fx:id="btnAvatar"
                        text="JM"
                        styleClass="header-avatar"
                        onAction="#onProfilClick" />
                </HBox>

                <!-- Bouton déconnexion -->
                <Button
                    fx:id="btnDeconnexion"
                    text="⎋"
                    styleClass="btn-icon"
                    style="-fx-text-fill: #93C5FD; -fx-font-size: 20px;"
                    onAction="#onDeconnexion"
                    tooltip="Se déconnecter" />
            </HBox>
        </HBox>
    </top>

    <!-- ============================================================
         SIDEBAR (LEFT)
         ============================================================ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">

            <!-- Section Principale -->
            <Label text="PRINCIPAL" styleClass="sidebar-section-label" />

            <Button
                fx:id="btnNavDashboard"
                text="  📊   Tableau de bord"
                styleClass="nav-btn, active"
                onAction="#onNavDashboard" />

            <Button
                fx:id="btnNavInscriptions"
                text="  🎓   Inscriptions"
                styleClass="nav-btn"
                onAction="#onNavInscriptions" />

            <Button
                fx:id="btnNavPedagogie"
                text="  📝   Notes & Bulletins"
                styleClass="nav-btn"
                onAction="#onNavPedagogie" />

            <!-- Section Finance -->
            <Label text="FINANCE" styleClass="sidebar-section-label" />

            <Button
                fx:id="btnNavFinance"
                text="  💰   Suivi Financier"
                styleClass="nav-btn"
                onAction="#onNavFinance" />

            <!-- Section Documents -->
            <Label text="DOCUMENTS" styleClass="sidebar-section-label" />

            <Button
                fx:id="btnNavDocuments"
                text="  🖨️   Documents & Rapports"
                styleClass="nav-btn"
                onAction="#onNavDocuments" />

            <!-- Espace flexible -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Séparateur -->
            <Pane styleClass="nav-separator" prefHeight="1"
                  style="-fx-background-color: rgba(255,255,255,0.07); -fx-margin: 0 16;" />

            <!-- Paramètres en bas -->
            <Label text="ADMINISTRATION" styleClass="sidebar-section-label" />

            <Button
                fx:id="btnNavParametres"
                text="  ⚙️   Paramètres"
                styleClass="nav-btn"
                onAction="#onNavParametres" />

            <Pane prefHeight="12" />
        </VBox>
    </left>

    <!-- ============================================================
         WORKSPACE (CENTER) – Zone dynamique de contenu
         ============================================================ -->
    <center>
        <StackPane
            fx:id="stackPaneWorkspace"
            styleClass="workspace">
            <!-- Les vues enfants sont chargées dynamiquement par le contrôleur -->
        </StackPane>
    </center>

</BorderPane>
