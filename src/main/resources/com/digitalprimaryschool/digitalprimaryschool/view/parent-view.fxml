<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="25.0">
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <Button style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-padding: 8; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="16" style="-fx-icon-color: -color-fg-muted;"/></graphic>
                </Button>
                <VBox spacing="4.0">
                    <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: -color-fg-default;" text="Nouveau parent / tuteur" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: -color-fg-muted;" text="Enregistrer les informations du responsable légal" />
                </VBox>
            </HBox>

            <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(16,24,40,0.04), 10, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <FontIcon iconLiteral="fth-users" iconSize="16" style="-fx-icon-color: #F5A524;" />
                    <Label style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: -color-fg-default;" text="Informations du responsable" />
                </HBox>

                <GridPane hgap="20.0" vgap="18.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50.0" />
                        <ColumnConstraints percentWidth="50.0" />
                    </columnConstraints>

                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <HBox><Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Lien avec l'élève" /><Label style="-fx-text-fill: #D92D20;" text=" *" /></HBox>
                        <ComboBox maxWidth="1.7976931348623157E308" promptText="Sélectionner (Père, Mère, Tuteur...)" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Profession" />
                        <TextField maxWidth="1.7976931348623157E308" promptText="Ex: Enseignant, Ingénieur..." style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <HBox><Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Nom" /><Label style="-fx-text-fill: #D92D20;" text=" *" /></HBox>
                        <TextField maxWidth="1.7976931348623157E308" promptText="Nom de famille" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <HBox><Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Prénom" /><Label style="-fx-text-fill: #D92D20;" text=" *" /></HBox>
                        <TextField maxWidth="1.7976931348623157E308" promptText="Prénom" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <HBox><Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Téléphone principal" /><Label style="-fx-text-fill: #D92D20;" text=" *" /></HBox>
                        <TextField maxWidth="1.7976931348623157E308" promptText="Ex: +33 6 00 00 00 00" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Téléphone secondaire (Optionnel)" />
                        <TextField maxWidth="1.7976931348623157E308" promptText="Autre numéro de contact" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3">
                        <HBox><Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Adresse Email" /><Label style="-fx-text-fill: #D92D20;" text=" *" /></HBox>
                        <TextField maxWidth="1.7976931348623157E308" promptText="exemple@domaine.com" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>

                    <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                        <Label style="-fx-font-weight: 600; -fx-text-fill: -color-fg-default; -fx-font-size: 13px;" text="Adresse de résidence" />
                        <TextField maxWidth="1.7976931348623157E308" promptText="Laisser vide si identique à l'adresse de l'élève" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    </VBox>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="14.0">
                <Button style="-fx-background-color: transparent; -fx-text-fill: -color-fg-muted; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20;" text="Annuler" />
                <Button style="-fx-background-color: #16213A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand; -fx-font-size: 13px;" text="Enregistrer le parent" />
            </HBox>
        </VBox>
    </content>
</ScrollPane>