<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.AjoutEleveController"
      style="-fx-background-color: #16213A; -fx-background-radius: 14;">
    <children>

        <!-- Mini AppBar -->
        <HBox fx:id="modalAppBar" alignment="CENTER_LEFT" prefHeight="46.0" style="-fx-padding: 0 10 0 20;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Ajouter un élève" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#closeModal" style="-fx-background-color: transparent; -fx-cursor: hand;" styleClass="window-btn, close-btn">
                    <graphic><FontIcon iconLiteral="fth-x" iconSize="20" /></graphic>


                </Button>
            </children>
        </HBox>

        <!-- Formulaire -->
        <VBox spacing="16.0" style="-fx-padding: 0 30 30 30;">
            <children>

                <VBox spacing="6.0">
                    <Label style="-fx-text-fill: #B7C2DC;" text="Nom" />
                    <TextField fx:id="champNom" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label style="-fx-text-fill: #B7C2DC;" text="Prénom" />
                    <TextField fx:id="champPrenom" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label style="-fx-text-fill: #B7C2DC;" text="Date de naissance" />
                    <DatePicker fx:id="champDateNaissance" maxWidth="1.7976931348623157E308" style="-fx-background-color: #2A3B61; -fx-border-color: #3f5485;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label style="-fx-text-fill: #B7C2DC;" text="Classe" />
                    <ComboBox fx:id="comboClasse" maxWidth="1.7976931348623157E308" promptText="Sélectionner une classe" style="-fx-background-color: #2A3B61; -fx-border-color: #3f5485;" />
                </VBox>

                <Label fx:id="labelErreur" style="-fx-text-fill: #FCA5A5; -fx-font-size: 12px;" visible="false" managed="false" />

                <Button onAction="#enregistrer" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F5A524; -fx-text-fill: #16213A; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="Enregistrer" />
            </children>
        </VBox>

    </children>
</VBox>