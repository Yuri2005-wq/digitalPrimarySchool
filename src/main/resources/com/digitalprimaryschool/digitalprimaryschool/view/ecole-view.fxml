<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="650.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #F3F4F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/fx/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.EcoleController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox prefWidth="380.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
        <padding>
            <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
        </padding>

        <Text style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #1F2937;" text="Informations de l'Établissement" />
        <Separator style="-fx-opacity: 0.5;" />

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold;" text="Nom de l'école *" />
            <TextField fx:id="txtNom" promptText="Ex: Digital Primary School" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #D1D5DB; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold;" text="Adresse Physique *" />
            <TextField fx:id="txtAdresse" promptText="Ex: Douala, Cameroun" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #D1D5DB; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold;" text="Téléphone / Contact *" />
            <TextField fx:id="txtTelephone" promptText="Ex: +237 6xx xxx xxx" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #D1D5DB; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold;" text="Email Officiel" />
            <TextField fx:id="txtEmail" promptText="Ex: contact@school.com" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #D1D5DB; -fx-padding: 8;" />
        </VBox>

        <VBox spacing="5.0">
            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold;" text="Devise de l'école" />
            <TextField fx:id="txtDevise" promptText="Ex: Discipline - Travail - Succès" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #D1D5DB; -fx-padding: 8;" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <HBox spacing="10.0">
            <Button fx:id="btnAnnuler" maxWidth="1.1797693134862315E308" onAction="#handleAnnuler" style="-fx-background-color: #E5E7EB; -fx-text-fill: #374151; -fx-background-radius: 6; -fx-padding: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="Annuler" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEnregistrer" maxWidth="1.1797693134862315E308" onAction="#handleEnregistrer" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="Enregistrer" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>

    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <Text style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #1F2937;" text="Liste des Établissements" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnSupprimer" visible="false" onAction="#handleSupprimer" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 15; -fx-font-weight: bold; -fx-cursor: hand;" text="Supprimer Sélection" />
        </HBox>

        <TableView fx:id="tableEcole" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: transparent; -fx-overflow-changed: transparent;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colNom" prefWidth="180.0" text="Nom Établissement" />
                <TableColumn fx:id="colAdresse" prefWidth="130.0" text="Adresse" />
                <TableColumn fx:id="colTelephone" prefWidth="110.0" text="Téléphone" />
                <TableColumn fx:id="colEmail" prefWidth="120.0" text="Email" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</HBox>