<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    SaisieNotes.fxml – Grille de saisie des notes (Module Pédagogique)
    Contrôleur : SaisieNotesController.java
    La TableView expose des cellules editables pour la saisie directe.
    Validation visuelle : bordure rouge si note > noteMax.
-->
<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.NotesController"
    styleClass="workspace"
    style="-fx-padding: 0;">

    <!-- ── En-tête de page ──────────────────────────────── -->
    <top>
        <VBox spacing="16" style="-fx-padding: 28 32 16 32; -fx-background-color: #F8FAFC;">

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Pédagogie" styleClass="breadcrumb-label" />
                <Label text="›" styleClass="breadcrumb-label" />
                <Label text="Saisie des notes" styleClass="breadcrumb-current" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Grille de saisie des notes" styleClass="page-title" />
                    <Label
                        fx:id="lblContexteNote"
                        text="Sélectionnez une classe, une matière et une séquence"
                        styleClass="page-subtitle" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Indicateur de sauvegarde automatique -->
                <Label fx:id="lblAutoSave" text="" styleClass="label-info" />
            </HBox>

        </VBox>
    </top>

    <!-- ── Contenu central ──────────────────────────────── -->
    <center>
        <VBox spacing="16" style="-fx-padding: 0 32 24 32;">

            <!-- ── Barre de filtres ── -->
            <HBox styleClass="toolbar-section" spacing="16" alignment="CENTER_LEFT">

                <VBox spacing="4">
                    <Label text="Classe" styleClass="field-label" />
                    <ComboBox
                        fx:id="cmbClasseNote"
                        promptText="Sélectionner une classe"
                        styleClass="filter-combo"
                        prefWidth="180"
                         />
                </VBox>

                <VBox spacing="4">
                    <Label text="Matière" styleClass="field-label" />
                    <ComboBox
                        fx:id="cmbMatiere"
                        promptText="Sélectionner..."
                        styleClass="filter-combo"
                        prefWidth="200"
                         />
                </VBox>

                <VBox spacing="4">
                    <Label text="Séquence" styleClass="field-label" />
                    <ComboBox
                        fx:id="cmbSequence"
                        promptText="Séquence..."
                        styleClass="filter-combo"
                        prefWidth="160"
                         />
                </VBox>

                <VBox spacing="4">
                    <Label text="Note max" styleClass="field-label" />
                    <ComboBox
                        fx:id="cmbNoteMax"
                        styleClass="filter-combo"
                        prefWidth="100" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Recherche rapide élève -->
                <VBox spacing="4">
                    <Label text="Rechercher un élève" styleClass="field-label" />
                    <TextField
                        fx:id="txtRechercheEleve"
                        promptText="🔍  Nom ou matricule..."
                        styleClass="search-field"
                        prefWidth="220"
                         />
                </VBox>

            </HBox>

            <!-- ── Résumé statistiques de saisie ── -->
            <HBox spacing="12">
                <HBox styleClass="card" spacing="24" alignment="CENTER_LEFT"
                      prefHeight="60" HBox.hgrow="ALWAYS">
                    <VBox spacing="2">
                        <Label text="ÉLÈVES DANS LA CLASSE" styleClass="card-title" />
                        <Label fx:id="lblNbElevesClasse" text="—" styleClass="label-strong" />
                    </VBox>
                    <Pane styleClass="divider-v" prefWidth="1" prefHeight="36" />
                    <VBox spacing="2">
                        <Label text="NOTES SAISIES" styleClass="card-title" />
                        <Label fx:id="lblNotesSaisies" text="—" styleClass="label-strong"
                               style="-fx-text-fill: #0F766E;" />
                    </VBox>
                    <Pane styleClass="divider-v" prefWidth="1" prefHeight="36" />
                    <VBox spacing="2">
                        <Label text="ABSENTS / NON NOTÉS" styleClass="card-title" />
                        <Label fx:id="lblAbsents" text="—" styleClass="label-strong"
                               style="-fx-text-fill: #D97706;" />
                    </VBox>
                    <Pane styleClass="divider-v" prefWidth="1" prefHeight="36" />
                    <VBox spacing="2">
                        <Label text="MOYENNE DE CLASSE" styleClass="card-title" />
                        <Label fx:id="lblMoyenneClasse" text="—" styleClass="label-strong"
                               style="-fx-text-fill: #1E3A8A;" />
                    </VBox>
                    <Pane styleClass="divider-v" prefWidth="1" prefHeight="36" />
                    <VBox spacing="2">
                        <Label text="ERREURS DE SAISIE" styleClass="card-title" />
                        <Label fx:id="lblErreursSaisie" text="0" styleClass="label-strong"
                               style="-fx-text-fill: #DC2626;" />
                    </VBox>
                </HBox>
            </HBox>

            <!-- ── Grille des notes (TableView éditable) ── -->
            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Liste des élèves — Saisie des notes"
                           styleClass="form-section-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button
                        fx:id="btnToutAbsent"
                        text="Marquer tous absents"
                        styleClass="btn-secondary"
                        style="-fx-font-size: 11px; -fx-padding: 6 12;"
                         />
                    <Button
                        fx:id="btnEffacerNotes"
                        text="🗑  Effacer tout"
                        styleClass="btn-danger"
                        style="-fx-font-size: 11px; -fx-padding: 6 12;"
                         />
                </HBox>

                <TableView
                    fx:id="tblNotes"
                    styleClass="table-view-base"
                    VBox.vgrow="ALWAYS"
                    editable="true"
                    columnResizePolicy="CONSTRAINED_RESIZE_POLICY">

                    <columns>

                        <!-- N° de rang -->
                        <TableColumn
                            fx:id="colRang"
                            text="N°"
                            prefWidth="45"
                            sortable="false"
                            editable="false" />

                        <!-- Matricule -->
                        <TableColumn
                            fx:id="colMatriculeNote"
                            text="Matricule"
                            prefWidth="100"
                            editable="false" />

                        <!-- Nom & Prénom -->
                        <TableColumn
                            fx:id="colNomPrenomNote"
                            text="Nom &amp; Prénom"
                            prefWidth="210"
                            editable="false" />

                        <!-- Sexe -->
                        <TableColumn
                            fx:id="colSexeNote"
                            text="Sexe"
                            prefWidth="55"
                            editable="false" />

                        <!-- Note obtenue (cellule éditable TextField) -->
                        <TableColumn
                            fx:id="colNote"
                            text="Note obtenue"
                            prefWidth="130"
                            editable="true"
                            style="-fx-alignment: CENTER;" />

                        <!-- Note max (lecture seule, rappel) -->
                        <TableColumn
                            fx:id="colNoteMaxRappel"
                            text="/ Max"
                            prefWidth="70"
                            editable="false"
                            style="-fx-alignment: CENTER;" />

                        <!-- Note sur 20 (calculée automatiquement) -->
                        <TableColumn
                            fx:id="colNoteSur20"
                            text="/ 20 (calc.)"
                            prefWidth="100"
                            editable="false"
                            style="-fx-alignment: CENTER;" />

                        <!-- Statut absence -->
                        <TableColumn
                            fx:id="colAbsence"
                            text="Absent"
                            prefWidth="70"
                            editable="true"
                            style="-fx-alignment: CENTER;" />

                        <!-- Observations -->
                        <TableColumn
                            fx:id="colObsNote"
                            text="Observations"
                            prefWidth="150"
                            editable="true" />

                    </columns>

                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="📊" style="-fx-font-size: 32px;" />
                            <Label text="Sélectionnez une classe, une matière et une séquence pour commencer la saisie."
                                   styleClass="label-info"
                                   wrapText="true"
                                   style="-fx-text-alignment: center;" />
                        </VBox>
                    </placeholder>

                </TableView>

                <!-- Bannière d'erreur validation (visible si erreurs) -->
                <HBox
                    fx:id="banniereErreurNote"
                    styleClass="alert-banner-danger"
                    alignment="CENTER_LEFT"
                    spacing="12"
                    visible="false">
                    <Label text="⛔" style="-fx-font-size: 16px;" />
                    <Label
                        fx:id="lblDetailErreurNote"
                        text="Des notes saisies dépassent la valeur maximale autorisée (cellules en rouge)."
                        styleClass="alert-text-danger"
                        wrapText="true" />
                </HBox>

            </VBox>

        </VBox>
    </center>

    <!-- ── Barre d'actions (BOTTOM) ─────────────────────── -->
    <bottom>
        <HBox
            alignment="CENTER_RIGHT"
            spacing="12"
            style="-fx-padding: 16 32; -fx-background-color: #FFFFFF;
                   -fx-border-color: #E2E8F0 transparent transparent transparent;
                   -fx-border-width: 1 0 0 0;">

            <Label
                fx:id="lblStatutSauvegarde"
                text=""
                styleClass="label-info" />

            <Region HBox.hgrow="ALWAYS" />

            <Button
                fx:id="btnAnnulerNotes"
                text="Annuler"
                styleClass="btn-secondary"
                 />

            <Button
                fx:id="btnSauvegarderBrouillon"
                text="💾  Enregistrer le brouillon"
                styleClass="btn-secondary"
                 />

            <Button
                fx:id="btnValiderNotes"
                text="✔  Valider les notes"
                styleClass="btn-primary"
                 />

        </HBox>
    </bottom>

</BorderPane>
