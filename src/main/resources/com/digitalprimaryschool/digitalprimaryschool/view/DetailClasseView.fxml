<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<VBox prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.DetailClasseController">
    <children>
        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#handleRetour" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="fas-arrow-left" iconSize="20" iconColor="#64748b" />
                    </graphic>
                </Button>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="Détail de la classe" textFill="#0f172a">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblNomClasse" text="6ème A" textFill="#64748b">
                            <font>
                                <Font name="Segoe UI" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button mnemonicParsing="false" onAction="#handleModifier" style="-fx-background-color: #1e293b; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;" text="📝 Modifier"
                        />
                    </HBox>
                </VBox>
            </children>
        </HBox>

        <AnchorPane VBox.vgrow="ALWAYS">
            <children>
                <!-- Carte d'information de la classe -->
                <AnchorPane layoutX="20.0" layoutY="20.0" prefHeight="160.0" prefWidth="1060.0" style="-fx-background-color: #334155; -fx-background-radius: 12;" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
                    <children>
                        <VBox layoutX="30.0" layoutY="30.0" spacing="10.0">
                            <children>
                                <Label fx:id="lblNiveauClasse" text="6ème" textFill="#94a3b8">
                                    <font>
                                        <Font name="Segoe UI" size="14.0" />
                                    </font>
                                </Label>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label fx:id="lblSection" text="Section A" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="20.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblStatutClasse" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 8;" text="Active" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox layoutX="30.0" layoutY="100.0" spacing="40.0">
                            <children>
                                <VBox>
                                    <children>
                                        <Label text="Enseignant" textFill="#94a3b8">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblEnseignant" text="M. Karim" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox>
                                    <children>
                                        <Label text="Élèves" textFill="#94a3b8">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblNombreEleves" text="25" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox>
                                    <children>
                                        <Label text="Moyenne générale" textFill="#94a3b8">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblMoyenneClasse" text="13.5" textFill="#10b981">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>

                <!-- Tableau des élèves -->
                <VBox layoutX="20.0" layoutY="200.0" spacing="15.0" style="-fx-padding: 20 0;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="200.0">
                    <children>
                        <Label text="Liste des élèves" textFill="#0f172a">
                            <graphic><FontIcon iconLiteral="fth-users" iconSize="16" /></graphic>
                        </Label>

                        <TableView fx:id="tableEleves" prefHeight="400.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colMatricule" prefWidth="150.0" text="MATRICULE" />
                                <TableColumn fx:id="colNomEleve" prefWidth="200.0" text="NOM" />
                                <TableColumn fx:id="colPrenomEleve" prefWidth="200.0" text="PRÉNOM" />
                                <TableColumn fx:id="colSexe" prefWidth="100.0" style="-fx-alignment: CENTER;" text="SEXE" />
                                <TableColumn fx:id="colMoyenne" prefWidth="120.0" style="-fx-alignment: CENTER;" text="MOYENNE" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</VBox>