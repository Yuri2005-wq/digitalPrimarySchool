<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="800.0" prefWidth="1280.0" styleClass="root-pane" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.EleveController">

    <center>
        <VBox spacing="24" styleClass="content-area">
            <padding>
                <Insets bottom="20" left="30" right="30" top="20" />
            </padding>

            <VBox spacing="4">
                <Label styleClass="page-title" text="Élèves — CM1" />
                <Label styleClass="page-subtitle" text="8 élève(s) trouvé(s)" />
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <HBox alignment="CENTER_LEFT" maxWidth="450" spacing="10" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 14;" HBox.hgrow="ALWAYS">
                    <FontIcon iconColor="#94A3B8" iconLiteral="fth-search" iconSize="16" />
                    <TextField promptText="Rechercher un élève..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0; -fx-text-fill: #1E293B;" HBox.hgrow="ALWAYS" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <ComboBox fx:id="comboClasse" prefWidth="130.0" promptText="6ème A" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;" />

                <Button style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 8 16; -fx-cursor: hand; -fx-text-fill: #1E293B;" text="Filtres">
                    <graphic><FontIcon iconColor="#64748B" iconLiteral="fth-sliders" /></graphic>
                </Button>
            </HBox>

            <VBox style="-fx-padding: 12;" styleClass="card" VBox.vgrow="ALWAYS">
                <TableView fx:id="tableauEleves" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
