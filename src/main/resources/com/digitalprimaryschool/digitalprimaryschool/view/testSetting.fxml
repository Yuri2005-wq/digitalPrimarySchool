<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox spacing="30.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.TarifsScolariteController">
    <children>

        <VBox prefWidth="380.0" spacing="0.0" style="-fx-background-color: #16213A; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10); -fx-border-color: #2A3B61; -fx-border-radius: 15; -fx-border-width: 1;">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 25 20 25; -fx-border-color: #2A3B61; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Configuration des Tarifs" />
                    </children>
                </HBox>

                <VBox spacing="18.0" style="-fx-padding: 25;">
                    <children>

                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 13px;" text="Libellé du tarif (ex: Standard SIL)" />
                                <TextField fx:id="txtLibelle" promptText="Entrez l'intitulé..." style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 13px;" text="Classe liée" />
                                <ComboBox fx:id="comboClasse" maxWidth="1.7976931348623157E308" promptText="Sélectionner la classe" style="-fx-background-color: #2A3B61; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 5;" />
                            </children>
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 12px;" text="Frais Inscription" />
                                        <TextField fx:id="txtInscription" promptText="0" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 10;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 12px;" text="Montant APEE" />
                                        <TextField fx:id="txtApee" promptText="0" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 10;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 12px;" text="Tenue Scolaire" />
                                        <TextField fx:id="txtTenueScolaire" promptText="0" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 10;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #B7C2DC; -fx-font-size: 12px;" text="Tenue Sport" />
                                        <TextField fx:id="txtTenueSport" promptText="0" style="-fx-background-color: #2A3B61; -fx-text-fill: white; -fx-border-color: #3f5485; -fx-border-radius: 5; -fx-padding: 10;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" style="-fx-padding: 15 0 0 0;">
                            <children>
                                <Button fx:id="btnEnregistrer" maxWidth="1.7976931348623157E308" onAction="#handleEnregistrer" style="-fx-background-color: #F5A524; -fx-text-fill: #16213A; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8;" text="Enregistrer le Tarif">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                                <Button fx:id="btnAnnuler" maxWidth="1.7976931348623157E308" onAction="#handleAnnuler" style="-fx-background-color: transparent; -fx-text-fill: #B7C2DC; -fx-font-weight: 500; -fx-padding: 8;" text="Réinitialiser" />
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="45.0" style="-fx-background-color: #16213A; -fx-background-radius: 8; -fx-padding: 0 15 0 15; -fx-border-color: #2A3B61; -fx-border-radius: 8; -fx-border-width: 1;">
                    <children>
                        <FontIcon iconLiteral="fth-search" iconSize="16" style="-fx-icon-color: #B7C2DC;" />
                        <TextField fx:id="txtRecherche" promptText="Rechercher par libellé ou classe..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #5A73A3;" HBox.hgrow="ALWAYS">
                            <padding><Insets left="10.0" /></padding>
                        </TextField>
                    </children>
                </HBox>

                <TableView fx:id="tableTarifs" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLibelle" prefWidth="150.0" text="Libellé du Tarif" />
                        <TableColumn fx:id="colClasse" prefWidth="90.0" text="Classe" />
                        <TableColumn fx:id="colInscription" prefWidth="100.0" text="Inscription" />
                        <TableColumn fx:id="colApee" prefWidth="100.0" text="APEE" />
                        <TableColumn fx:id="colTenueScolaire" prefWidth="110.0" text="T. Scolaire" />
                        <TableColumn fx:id="colTenueSport" prefWidth="100.0" text="T. Sport" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>