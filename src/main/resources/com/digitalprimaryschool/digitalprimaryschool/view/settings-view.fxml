<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:id="settingsRoot" prefHeight="700.0" prefWidth="1000.0" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.SettingsController">

    <VBox style="-fx-background-color: #111a2e;">
        <children>

            <VBox spacing="5.0" style="-fx-padding: 25 30 15 30;">
                <children>
                    <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: white;" text="Configurations Système" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #B7C2DC;" text="Gérez les entités et paramètres de base de l'établissement scolaires." />
                </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="5.0" style="-fx-background-color: #16213A; -fx-padding: 0 30 0 30; -fx-border-color: #2A3B61; -fx-border-width: 0 0 1 0;">
                <children>
                    <Button fx:id="btnTabAnnee" onAction="#switchTab" styleClass="top-tab-btn" text="Années Scolaires">
                        <graphic>
                            <FontIcon iconLiteral="fth-calendar" iconSize="16" />
                        </graphic>
                    </Button>
                    <Button fx:id="btnTabTrimestre" onAction="#switchTab" styleClass="top-tab-btn" text="Trimestres" />
                    <Button fx:id="btnTabSequence" onAction="#switchTab" styleClass="top-tab-btn" text="Séquences" />
                    <Button fx:id="btnTabTarif" onAction="#switchTab" styleClass="top-tab-btn" text="Tarifs">
                        <graphic>
                            <FontIcon iconLiteral="fth-credit-card" iconSize="16"/>
                        </graphic>
                    </Button>
                    <Button fx:id="btnTabTranche" onAction="#switchTab" styleClass="top-tab-btn" text="Tranches">
                        <graphic>
                            <FontIcon iconLiteral="fth-dollar-sign" iconSize="16"/>
                        </graphic>
                    </Button>
                    <Button fx:id="btnTabClasse" onAction="#switchTab" styleClass="top-tab-btn" text="Classes">
                        <graphic>
                            <FontIcon iconLiteral="fth-layers" iconSize="16"/>
                        </graphic>
                    </Button>
                </children>
            </HBox>

            <StackPane fx:id="tabContentContainer" style="-fx-background-color: #111a2e; -fx-padding: 25;" VBox.vgrow="ALWAYS" />

        </children>
    </VBox>
</StackPane>