<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<!--
    LOGIN.fxml – Écran de connexion
    Contrôleur : LoginController.java
    Résolution minimum supportée : 1280×768
-->
<StackPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cm.siantou.ecole.controller.LoginController"
    styleClass="login-root"
    stylesheets="@../css/style.css">

    <!-- Fond dégradé géré par CSS (.login-root) -->

    <!-- Carte centrée -->
    <VBox
        styleClass="login-card"
        alignment="CENTER"
        spacing="0"
        maxWidth="400"
        maxHeight="520">

        <!-- Logo + Titre -->
        <VBox alignment="CENTER" spacing="8">
            <!-- Remplacer ImageView src par le vrai logo -->
            <Label text="🏫" style="-fx-font-size: 48px;" />
            <Label
                fx:id="lblAppTitle"
                text="Gestion Scolaire"
                styleClass="login-title" />
            <Label
                fx:id="lblSchoolName"
                text="École Primaire Privée"
                styleClass="login-subtitle" />
        </VBox>

        <!-- Séparateur -->
        <Pane prefHeight="32" />

        <!-- Formulaire -->
        <VBox spacing="6">
            <Label text="Identifiant" styleClass="login-label" />
            <TextField
                fx:id="txtIdentifiant"
                promptText="Ex : economat@ecole.cm"
                styleClass="login-field"
                prefWidth="308" />
        </VBox>

        <Pane prefHeight="16" />

        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT" spacing="4">
                <Label text="Mot de passe" styleClass="login-label" />
            </HBox>
            <PasswordField
                fx:id="txtMotDePasse"
                promptText="••••••••"
                styleClass="login-field"
                prefWidth="308" />
        </VBox>

        <Pane prefHeight="8" />

        <!-- Message d'erreur (caché par défaut) -->
        <Label
            fx:id="lblErreur"
            text=""
            styleClass="login-error"
            visible="false"
            wrapText="true"
            maxWidth="308" />

        <Pane prefHeight="24" />

        <!-- Bouton connexion -->
        <Button
            fx:id="btnConnecter"
            text="SE CONNECTER"
            styleClass="btn-primary"
            prefWidth="308"
            prefHeight="44"
            onAction="#onConnexion" />

        <Pane prefHeight="20" />

        <!-- Pied de page -->
        <Label
            text="© 2025 – Système de Gestion Scolaire MINEDUB"
            styleClass="login-subtitle"
            alignment="CENTER" />
    </VBox>
</StackPane>
