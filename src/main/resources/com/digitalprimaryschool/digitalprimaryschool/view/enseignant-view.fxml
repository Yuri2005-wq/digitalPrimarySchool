<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox spacing="25.0">
            <padding>
                <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="4.0">
                    <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: -color-fg-default;" text="Gestion des Classes" />
                    <Label style="-fx-font-size: 13px; -fx-text-fill: -color-fg-muted;" text="Consulter, ajouter, modifier ou supprimer les classes de l'établissement" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(16,24,40,0.04), 10, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6 12;" HBox.hgrow="ALWAYS" maxWidth="400.0">
                    <FontIcon iconLiteral="fth-search" iconSize="16" style="-fx-icon-color: -color-fg-muted;" />
                    <TextField promptText="Rechercher une classe (ex: CM2)..." style="-fx-background-color: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button style="-fx-background-color: #16213A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fth-plus" iconSize="16" style="-fx-icon-color: white;"/> </graphic>
                    <text>Nouvelle Classe</text>
                </Button>
            </HBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(16,24,40,0.04), 10, 0, 0, 2);">
                <TableView fx:id="classesTable" styleClass="striped" minHeight="400.0">
                    <columns>
                        <TableColumn fx:id="colIdClasse" text="ID" prefWidth="80.0" />
                        <TableColumn fx:id="colNomClasse" text="Nom de la classe" prefWidth="250.0" />
                        <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="180.0" />
                        <TableColumn fx:id="colEffectif" text="Effectif (Élèves)" prefWidth="150.0" />
                        <TableColumn fx:id="colEnseignant" text="Enseignant Principal" prefWidth="250.0" />
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="150.0" style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </content>
</ScrollPane>