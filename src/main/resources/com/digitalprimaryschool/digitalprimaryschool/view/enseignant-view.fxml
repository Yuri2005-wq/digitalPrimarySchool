<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="20" styleClass="content-area" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.EnseignantController">
    <padding>
        <Insets bottom="25" left="30" right="30" top="25" />
    </padding>

    <VBox spacing="4">
        <Label styleClass="page-title" text="Gestion du Personnel Enseignant" />
        <Label styleClass="page-subtitle" text="Inscrivez les enseignants, modifiez leurs profils et assignez-les à une classe" />
    </VBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">

        <VBox maxWidth="400" prefWidth="400.0" spacing="15" styleClass="card" HBox.hgrow="NEVER">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-padding: 8; -fx-background-radius: 8;" styleClass="icon-orange">
                    <FontIcon iconColor="#F5A524" iconLiteral="fth-user" iconSize="18" />
                </StackPane>
                <Label styleClass="card-title" text="Détails de l'Enseignant" />
            </HBox>
            <Separator />

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="Nom de famille *" />
                <TextField fx:id="txtNom" promptText="Ex: KAMGA" styleClass="input" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="Prénom" />
                <TextField fx:id="txtPrenom" promptText="Ex: Pierre" styleClass="input" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" text="Téléphone / Contact *" />
                <TextField fx:id="txtContact" promptText="Ex: 6XXXXXXXX" styleClass="input" />
            </VBox>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold;" text="Diplôme / Qualification" />
                    <TextField fx:id="txtQualification" promptText="Ex: CAPIEMP" styleClass="input" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold;" text="Grade / Catégorie" />
                    <TextField fx:id="txtGrade" promptText="Ex: Vacataire" styleClass="input" />
                </VBox>
            </HBox>

            <Separator />

            <VBox spacing="5">
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <FontIcon iconColor="#16213A" iconLiteral="fth-layers" iconSize="14" />
                    <Label style="-fx-font-weight: bold;" text="Classe assignée (Optionnel)" />
                </HBox>
                <ComboBox fx:id="comboAffectClasse" maxWidth="1.7976931348623157E308" promptText="-- Choisir une classe --" styleClass="input" prefHeight="37.0" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="btnAnnuler" onAction="#handleClear" style="-fx-background-color: #E2E8F0; -fx-text-fill: #4A5568; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Vider">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                </Button>
                <Button fx:id="btnEnregistrer" onAction="#handleEnregistrer" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Enregistrer">
                    <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                </Button>
            </HBox>
        </VBox>

        <VBox spacing="12" styleClass="card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-padding: 8; -fx-background-radius: 8;" styleClass="icon-gray">
                    <FontIcon iconColor="#16213A" iconLiteral="fth-list" iconSize="18" />
                </StackPane>
                <Label styleClass="card-title" text="Membres du personnel enregistrés" />
                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnSupprimer" onAction="#handleSupprimer" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Supprimer">
                    <graphic><FontIcon iconColor="white" iconLiteral="fth-trash-2" /></graphic>
                    <padding><Insets bottom="6.0" left="12.0" right="12.0" top="6.0" /></padding>
                </Button>
            </HBox>
            <Separator />

            <TableView fx:id="tableEnseignants" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNom" prefWidth="130.0" text="Nom" />
                    <TableColumn fx:id="colPrenom" prefWidth="130.0" text="Prénom" />
                    <TableColumn fx:id="colContact" prefWidth="110.0" text="Contact / Téléphone" />
                    <TableColumn fx:id="colQualification" prefWidth="100.0" text="Qualification" />
                    <TableColumn fx:id="colClasse" prefWidth="140.0" text="Classe Tenue" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</VBox>