<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="800.0" prefWidth="1280.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://www.w3.org/1999/xlink" fx:controller="com.digitalprimaryschool.digitalprimaryschool.controller.ClasseController">

    <left>
        <VBox prefWidth="260.0" styleClass="sidebar" spacing="5">
            <padding>
                <Insets top="25" right="15" bottom="25" left="15"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="sidebar-header">
                <StackPane styleClass="logo-container">
                    <Circle radius="18" fill="#FFB300"/>
                    <FontIcon iconLiteral="fth-book-open" iconSize="18" iconColor="white"/>
                </StackPane>
                <VBox>
                    <Label text="EduGestion" styleClass="logo-title"/>
                    <Label text="Gestion scolaire" styleClass="logo-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="30"/>

            <Label text="PRINCIPAL" styleClass="sidebar-section-title"/>
            <Button text="Tableau de bord" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-grid"/></graphic>
            </Button>
            <Button text="Élèves" styleClass="sidebar-btn, active">
                <graphic><FontIcon iconLiteral="fth-users"/></graphic>
            </Button>
            <Button text="Enseignants" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-award"/></graphic>
            </Button>
            <Button text="Classes" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-book"/></graphic>
            </Button>
            <Button text="Emploi du temps" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-calendar"/></graphic>
            </Button>
            <Button text="Notes &amp; Bulletins" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-file-text"/></graphic>
            </Button>

            <Region prefHeight="20"/>

            <Label text="SYSTÈME" styleClass="sidebar-section-title"/>
            <Button text="Notifications" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-bell"/></graphic>
            </Button>
            <Button text="Paramètres" styleClass="sidebar-btn">
                <graphic><FontIcon iconLiteral="fth-settings"/></graphic>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button text="Déconnexion" styleClass="sidebar-btn, btn-logout">
                <graphic><FontIcon iconLiteral="fth-log-out"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="20">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="top-bar">
                <Button styleClass="btn-icon-flat">
                    <graphic><FontIcon iconLiteral="fth-sidebar" iconSize="18"/></graphic>
                </Button>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane styleClass="avatar-container">
                    <Circle radius="16" fill="#1A237E"/>
                    <Label text="AD" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;"/>
                </StackPane>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button styleClass="btn-back">
                    <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="16"/></graphic>
                </Button>
                <VBox>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Élèves — 6ème A" styleClass="view-title"/>
                    </HBox>
                    <Label text="8 élève(s) trouvé(s)" styleClass="view-subtitle"/>
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS" maxWidth="500">
                    <FontIcon iconLiteral="fth-search" iconColor="#94A3B8" styleClass="search-icon"/>
                    <TextField promptText="Rechercher un élève..." styleClass="search-input" HBox.hgrow="ALWAYS"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="comboClasse" prefWidth="120.0" promptText="6ème A" styleClass="filter-combo"/>
                <Button text="Filtres" styleClass="btn-filter">
                    <graphic><FontIcon iconLiteral="fth-sliders"/></graphic>
                </Button>
            </HBox>

            <TableView fx:id="tableauEleves" VBox.vgrow="ALWAYS" styleClass="custom-table">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>